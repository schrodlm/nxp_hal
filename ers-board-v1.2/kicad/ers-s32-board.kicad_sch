	(text "Soft-start for PROG (see AN13033, sect. 10)\nProgrammer is available only when the board\nis powered from USB. Otherwise it is kept unpowered."
		(exclude_from_sim no)
		(at 190.5 83.82 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "1202e1c3-908b-4566-bdac-c14136e12c2d")
	)
	(text "Power routing"
		(exclude_from_sim no)
		(at 203.2 200.66 0)
		(effects
			(font
				(size 1.778 1.778)
			)
			(justify left top)
		)
		(uuid "2aa78fc4-c0a6-475a-8daa-95f83394606a")
	)
	(text "Controller, peripherals and STM32F4DISCOVERY.\nThe direct links may be scratched off and a pin header intalled.\nThen the power routing may be controlled by jumpers."
		(exclude_from_sim no)
		(at 203.2 208.28 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left top)
		)
		(uuid "4ca9db0f-7bab-4127-9503-752e342f3d7e")
	)
	(text "VCC_5V may come from USB \nor from POWER pin header\n(typically from the STM32F4DISCOVERY connector)"
		(exclude_from_sim no)
		(at 154.94 40.64 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "61a9cb21-5fd7-4f81-91f1-2e609a68c5bb")
	)
	(text "TARGET_SWO is unused because\nS32K1xx does not support SWO.\nIt is kept high by a pull-up."
		(exclude_from_sim no)
		(at 195.58 129.54 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "84257a5e-59bc-422e-b26e-0445fc9ca2e8")
	)
	(text "By default, PROG is connected to CTRL. Only RESETN is disconnected.\nIt allows the CTRL to be programmed for the first time (becaue \nwhen unprogrammed, CTRL asserts RESETN which keeps PROG\nin bootloader mode). Once programmed, the JP3 is to be closed.\nOptionally, J6 can be populated and the default connections \nbetween CTRL and PROG scratched off."
		(exclude_from_sim no)
		(at 195.072 88.138 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "9a21b28b-b712-410c-828d-4227b7266431")
	)
	(text "Open: Boot from internal FLASH\nClosed: Enable ISP mode (USB on UART)"
		(exclude_from_sim no)
		(at 162.56 170.18 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "9dbf50fc-9cee-4e75-9266-9ba83055cffc")
	)
